# stg + windows-gpu (shared workstation generation node)
AI_ENGINE_MODELS_DIR=./models
LLAMA_MODEL_FILE=Qwen2.5-7B-Instruct-Q4_K_M.gguf

LLAMA_PORT=7002
STATS_PORT=7000
API_PORT=7001

AUTO_EXPOSE_PUBLIC_PORTS=false

AUTO_EXPOSE_CLOUDFLARE_LLAMA_TUNNEL=true
CLOUDFLARE_LLAMA_TUNNEL_CONTAINER=axiomnode-llama-cloudflared
CLOUDFLARE_LLAMA_TARGET_FILE=data/llama-cloudflare-target.json

AUTO_EXPOSE_VPS_RELAY=true
VPS_RELAY_SSH_HOST=sebss@amksandbox.cloud
VPS_RELAY_SSH_KEY=~/.ssh/axiomnode_k3s_ci
VPS_RELAY_PUBLIC_HOST=195.35.48.40
VPS_RELAY_STATS_PUBLIC_PORT=27000
VPS_RELAY_API_PUBLIC_PORT=27001
VPS_RELAY_STATS_TUNNEL_PORT=27100
VPS_RELAY_API_TUNNEL_PORT=27101

LLAMA_CTX_SIZE=4096
LLAMA_THREADS=12
LLAMA_BATCH=1536
LLAMA_N_GPU_LAYERS=99
LLAMA_PARALLEL=2

LLAMA_CPUS=10.0
LLAMA_MEMORY_LIMIT=22g
LLAMA_MEMORY_RESERVATION=16g
LLAMA_SHM_SIZE=3g

API_CPUS=5.0
API_MEMORY_LIMIT=10g
API_MEMORY_RESERVATION=8g
API_SHM_SIZE=2g
API_WORKERS=1

STATS_CPUS=1.5
STATS_MEMORY_LIMIT=1g
STATS_MEMORY_RESERVATION=512m
STATS_WORKERS=1

CACHE_CPUS=0.5
CACHE_MEMORY_LIMIT=512m
CACHE_MEMORY_RESERVATION=256m

AI_ENGINE_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
AI_ENGINE_EMBEDDING_DEVICE=cpu
AI_ENGINE_EMBEDDING_BATCH_SIZE=96
AI_ENGINE_LLAMA_TIMEOUT_SECONDS=900
AI_ENGINE_LLAMA_MAX_CONCURRENT_REQUESTS=3
AI_ENGINE_GENERATION_MAX_IN_FLIGHT=6
AI_ENGINE_GENERATION_MAX_QUEUE_SIZE=12
AI_ENGINE_QUERY_EMBEDDING_CACHE_MAX_ENTRIES=4096
AI_ENGINE_RETRIEVAL_RESULT_CACHE_MAX_ENTRIES=2048
AI_ENGINE_RAG_CONTEXT_CHAR_LIMIT=4600
AI_ENGINE_CACHE_WARMUP_ENABLED=false
AI_ENGINE_GENERATION_API_URL=http://ai-api:8001
AI_ENGINE_GENERATION_CACHE_BACKEND=redis
AI_ENGINE_GENERATION_CACHE_PATH=/app/data/generation_cache.json
AI_ENGINE_GENERATION_CACHE_REDIS_URL=redis://ai-cache:6379/0
AI_ENGINE_GENERATION_CACHE_REDIS_PREFIX=ai-engine:generation-cache
AI_ENGINE_GENERATION_CACHE_NAMESPACE=stg-gpu-v1

AI_ENGINE_RATE_LIMIT_ENABLED=true
AI_ENGINE_RATE_LIMIT_REQUESTS=180
AI_ENGINE_RATE_LIMIT_WINDOW_SECONDS=60

APP_NAME=ai_engine

AI_ENGINE_DISTRIBUTION=stg
AI_ENGINE_RELEASE_VERSION=workstation-gpu
AI_ENGINE_API_KEY=
AI_ENGINE_GAMES_API_KEY=
AI_ENGINE_BRIDGE_API_KEY=
