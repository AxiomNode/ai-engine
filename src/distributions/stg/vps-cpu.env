# stg + vps-cpu
AI_ENGINE_MODELS_DIR=./models
LLAMA_MODEL_FILE=Qwen2.5-3B-Instruct-Q4_K_M.gguf

LLAMA_PORT=8080
STATS_PORT=8000
API_PORT=8001

LLAMA_CTX_SIZE=2048
LLAMA_THREADS=2
LLAMA_BATCH=256

LLAMA_CPUS=2.0
LLAMA_MEMORY_LIMIT=6g
LLAMA_MEMORY_RESERVATION=4g
LLAMA_SHM_SIZE=1g

API_CPUS=1.5
API_MEMORY_LIMIT=3g
API_MEMORY_RESERVATION=2g
API_SHM_SIZE=512m
API_WORKERS=1

STATS_CPUS=0.5
STATS_MEMORY_LIMIT=512m
STATS_MEMORY_RESERVATION=256m
STATS_WORKERS=1

AI_ENGINE_EMBEDDING_MODEL=all-MiniLM-L6-v2
AI_ENGINE_LLAMA_TIMEOUT_SECONDS=420
AI_ENGINE_GENERATION_API_URL=http://ai-api:8001
AI_ENGINE_GENERATION_CACHE_BACKEND=redis
AI_ENGINE_GENERATION_CACHE_PATH=/app/data/generation_cache.json
AI_ENGINE_GENERATION_CACHE_REDIS_URL=redis://ai-cache:6379/0
AI_ENGINE_GENERATION_CACHE_REDIS_PREFIX=ai-engine:generation-cache
AI_ENGINE_GENERATION_CACHE_NAMESPACE=stg-v1

AI_ENGINE_RATE_LIMIT_ENABLED=true
AI_ENGINE_RATE_LIMIT_REQUESTS=90
AI_ENGINE_RATE_LIMIT_WINDOW_SECONDS=60

APP_NAME=AxiomNode
API_SERVICE_NAME=ai_api
STATS_SERVICE_NAME=ai_stats
LLAMA_CPU_SERVICE_NAME=llama_server_cpu
LLAMA_GPU_SERVICE_NAME=llama_server_gpu

AI_ENGINE_DISTRIBUTION=stg
AI_ENGINE_RELEASE_VERSION=v1
AI_ENGINE_API_KEY=stg_api_test_key_2026
AI_ENGINE_GAMES_API_KEY=stg_games_test_key_2026
AI_ENGINE_BRIDGE_API_KEY=stg_bridge_test_key_2026
AI_ENGINE_STATS_API_KEY=stg_stats_test_key_2026
