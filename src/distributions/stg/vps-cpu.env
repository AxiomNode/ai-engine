# stg + vps-cpu  (target: VPS 8 cores / 32 GB RAM — staging profile)
AI_ENGINE_MODELS_DIR=./models
LLAMA_MODEL_FILE=Qwen2.5-7B-Instruct-Q4_K_M.gguf

LLAMA_PORT=8080
STATS_PORT=8000
API_PORT=8001

# ── LLM inference (native llama.cpp server) ──────────────────────────────────
LLAMA_CTX_SIZE=2048
LLAMA_THREADS=4
LLAMA_BATCH=512
LLAMA_PARALLEL=2

LLAMA_CPUS=4.0
LLAMA_MEMORY_LIMIT=10g
LLAMA_MEMORY_RESERVATION=6g
LLAMA_SHM_SIZE=1g

# ── AI API ───────────────────────────────────────────────────────────────────
API_CPUS=1.5
API_MEMORY_LIMIT=4g
API_MEMORY_RESERVATION=2g
API_SHM_SIZE=512m
API_WORKERS=2

# ── Stats / Observability ────────────────────────────────────────────────────
STATS_CPUS=0.5
STATS_MEMORY_LIMIT=512m
STATS_MEMORY_RESERVATION=256m
STATS_WORKERS=1

# ── Cache (Redis) ────────────────────────────────────────────────────────────
CACHE_CPUS=0.25
CACHE_MEMORY_LIMIT=256m
CACHE_MEMORY_RESERVATION=128m

# ── Application config ───────────────────────────────────────────────────────
AI_ENGINE_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
AI_ENGINE_EMBEDDING_DEVICE=cpu
AI_ENGINE_EMBEDDING_BATCH_SIZE=32
AI_ENGINE_VECTOR_STORE_BACKEND=chroma
AI_ENGINE_VECTOR_STORE_PATH=/app/data/chroma
AI_ENGINE_VECTOR_STORE_COLLECTION=ai_engine_stg
AI_ENGINE_LLAMA_TIMEOUT_SECONDS=1800
AI_ENGINE_GENERATION_API_URL=http://ai-api:8001
AI_ENGINE_GENERATION_CACHE_BACKEND=redis
AI_ENGINE_GENERATION_CACHE_PATH=/app/data/generation_cache.json
AI_ENGINE_GENERATION_CACHE_REDIS_URL=redis://ai-cache:6379/0
AI_ENGINE_GENERATION_CACHE_REDIS_PREFIX=ai-engine:generation-cache
AI_ENGINE_GENERATION_CACHE_NAMESPACE=stg-v1

AI_ENGINE_RATE_LIMIT_ENABLED=true
AI_ENGINE_RATE_LIMIT_REQUESTS=90
AI_ENGINE_RATE_LIMIT_WINDOW_SECONDS=60

APP_NAME=ai_engine

AI_ENGINE_DISTRIBUTION=stg
AI_ENGINE_RELEASE_VERSION=v1
AI_ENGINE_API_KEY=
AI_ENGINE_GAMES_API_KEY=
AI_ENGINE_BRIDGE_API_KEY=
AI_ENGINE_STATS_API_KEY=
