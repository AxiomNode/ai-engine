# dev + windows
AI_ENGINE_MODELS_DIR=./models
LLAMA_MODEL_FILE=Qwen2.5-3B-Instruct-Q4_K_M.gguf

LLAMA_PORT=18080
STATS_PORT=8000
API_PORT=8001

LLAMA_CTX_SIZE=2048
LLAMA_THREADS=4
LLAMA_BATCH=256

LLAMA_CPUS=4.0
LLAMA_MEMORY_LIMIT=8g
LLAMA_MEMORY_RESERVATION=4g
LLAMA_SHM_SIZE=1g

API_CPUS=2.0
API_MEMORY_LIMIT=4g
API_MEMORY_RESERVATION=2g
API_SHM_SIZE=1g
API_WORKERS=1

STATS_CPUS=1.0
STATS_MEMORY_LIMIT=1g
STATS_MEMORY_RESERVATION=512m
STATS_WORKERS=1

AI_ENGINE_EMBEDDING_MODEL=all-MiniLM-L6-v2
AI_ENGINE_GENERATION_CACHE_BACKEND=tinydb
AI_ENGINE_GENERATION_CACHE_PATH=/app/data/generation_cache.json
AI_ENGINE_GENERATION_CACHE_REDIS_PREFIX=ai-engine:generation-cache
AI_ENGINE_GENERATION_CACHE_NAMESPACE=dev-v1

AI_ENGINE_RATE_LIMIT_ENABLED=false
AI_ENGINE_RATE_LIMIT_REQUESTS=120
AI_ENGINE_RATE_LIMIT_WINDOW_SECONDS=60

AI_ENGINE_DISTRIBUTION=dev
AI_ENGINE_RELEASE_VERSION=v1
