# dev + vps-cpu
AI_ENGINE_MODELS_DIR=./models
LLAMA_MODEL_FILE=Qwen2.5-3B-Instruct-Q4_K_M.gguf

LLAMA_PORT=8080
STATS_PORT=8000
API_PORT=8001

LLAMA_CTX_SIZE=4096
LLAMA_THREADS=2
LLAMA_BATCH=256

LLAMA_CPUS=1.5
LLAMA_MEMORY_LIMIT=4g
LLAMA_MEMORY_RESERVATION=2g
LLAMA_SHM_SIZE=512m

API_CPUS=0.75
API_MEMORY_LIMIT=1536m
API_MEMORY_RESERVATION=1g
API_SHM_SIZE=256m
API_WORKERS=1

STATS_CPUS=0.25
STATS_MEMORY_LIMIT=256m
STATS_MEMORY_RESERVATION=128m
STATS_WORKERS=1

AI_ENGINE_EMBEDDING_MODEL=all-MiniLM-L6-v2
AI_ENGINE_LLAMA_TIMEOUT_SECONDS=300
AI_ENGINE_GENERATION_API_URL=http://ai-api:8001
AI_ENGINE_GENERATION_CACHE_BACKEND=redis
AI_ENGINE_GENERATION_CACHE_PATH=/app/data/generation_cache.json
AI_ENGINE_GENERATION_CACHE_REDIS_URL=redis://ai-cache:6379/0
AI_ENGINE_GENERATION_CACHE_REDIS_PREFIX=ai-engine:generation-cache
