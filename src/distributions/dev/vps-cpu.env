AI_ENGINE_RATE_LIMIT_ENABLED=false
AI_ENGINE_RATE_LIMIT_REQUESTS=120
AI_ENGINE_RATE_LIMIT_WINDOW_SECONDS=60

APP_NAME=axiomnode
API_SERVICE_NAME=ai_api
STATS_SERVICE_NAME=ai_stats
LLAMA_CPU_SERVICE_NAME=llama_server_cpu
LLAMA_GPU_SERVICE_NAME=llama_server_gpu

