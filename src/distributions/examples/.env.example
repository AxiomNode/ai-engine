# ──────────────────────────────────────────────────────────────────────────────
# AxiomNode – ai-engine environment variables
# Copy this file to .env and fill in the values:
#   cp src/distributions/examples/.env.example src/.env
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ---------------------------------------------------------------------------
# Models
# ---------------------------------------------------------------------------

# Absolute path to the directory containing GGUF model files.
# Default: <project-root>/src/models/
AI_ENGINE_MODELS_DIR=./models

# GGUF model filename to load in the llama-server container.
# Must exist inside AI_ENGINE_MODELS_DIR.
# Available models: Qwen2.5-7B-Instruct-Q4_K_M.gguf (recommended, ~4.8 GB)
#                   Phi-3.5-mini-instruct-Q4_K_M.gguf (~2.4 GB)
#                   Qwen2.5-3B-Instruct-Q4_K_M.gguf   (~2 GB)
LLAMA_MODEL_FILE=Qwen2.5-7B-Instruct-Q4_K_M.gguf

# Context window size for the llama.cpp server (tokens).
# Larger values use more VRAM/RAM. 4096 fits most single requests.
LLAMA_CTX_SIZE=4096

# CPU-only tuning for llama.cpp server.
# LLAMA_THREADS should usually match available vCPUs for the service.
LLAMA_THREADS=6
LLAMA_BATCH=512

# GPU image used by the compose gpu profile.
# The upstream registry currently publishes versioned CUDA tags instead of a
# stable `server-cuda` floating tag, so keep this pinned unless you validate a
# newer release.
LLAMA_GPU_IMAGE=ghcr.io/ggerganov/llama.cpp:server-cuda-b4719

# Docker Compose resource limits for llama-server.
# These values only take effect if Docker Desktop / WSL has enough RAM and CPU assigned.
LLAMA_CPUS=6.0
LLAMA_MEMORY_LIMIT=12g
LLAMA_MEMORY_RESERVATION=8g
LLAMA_SHM_SIZE=2g

# ---------------------------------------------------------------------------
# Service ports (host-side)
# ---------------------------------------------------------------------------

# llama.cpp inference server published on the host
LLAMA_PORT=7002

# ai-engine observability / statistics API published on the host
STATS_PORT=7000

# Docker Compose resource limits for ai-stats.
STATS_CPUS=1.0
STATS_MEMORY_LIMIT=1g
STATS_MEMORY_RESERVATION=512m

# ai-engine generation API – POST /generate, POST /ingest, GET /stats published on the host
API_PORT=7001

# Automatic Windows host exposure for public TCP ports.
# When enabled, deploy.ps1 configures firewall rules and portproxy listeners.
AUTO_EXPOSE_PUBLIC_PORTS=false

# Optional public TCP ports. Leave empty to avoid publishing a public listener.
# When a public port matches the host port, only the firewall rule is created.
LLAMA_PUBLIC_PORT=
STATS_PUBLIC_PORT=
API_PUBLIC_PORT=

# Preferred staging topology when ai-engine runs on a Windows workstation and
# the rest of the platform runs on the VPS Kubernetes cluster.
# This opens an SSH reverse tunnel from the workstation to the VPS and runs a
# tiny TCP relay on the VPS, so cluster services reach ai-engine through the VPS.
AUTO_EXPOSE_VPS_RELAY=false
VPS_RELAY_SSH_HOST=sebss@example.com
VPS_RELAY_SSH_KEY=~/.ssh/axiomnode_k3s_ci
VPS_RELAY_PUBLIC_HOST=
VPS_RELAY_STATS_PUBLIC_PORT=27000
VPS_RELAY_API_PUBLIC_PORT=27001
VPS_RELAY_STATS_TUNNEL_PORT=27100
VPS_RELAY_API_TUNNEL_PORT=27101

# Docker Compose resource limits for ai-api.
API_CPUS=4.0
API_MEMORY_LIMIT=8g
API_MEMORY_RESERVATION=4g
API_SHM_SIZE=1g

# Uvicorn worker count for ai-api. Increase only if you have enough CPU/RAM.
API_WORKERS=2

# Uvicorn worker count for ai-stats (usually 1 is enough on a VPS).
STATS_WORKERS=1

# ---------------------------------------------------------------------------
# Generation API – LLM and embedding configuration
# ---------------------------------------------------------------------------

# sentence-transformers model used for RAG embeddings in the generation API.
# The runtime corpus is English-only, but this compact model keeps compatibility
# with existing vector dimensions and has a small CPU/RAM footprint.
AI_ENGINE_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
AI_ENGINE_EMBEDDING_DEVICE=cpu
AI_ENGINE_EMBEDDING_BATCH_SIZE=32
AI_ENGINE_VECTOR_STORE_BACKEND=chroma
AI_ENGINE_VECTOR_STORE_PATH=/app/data/chroma
AI_ENGINE_VECTOR_STORE_COLLECTION=ai_engine_default
AI_ENGINE_LLAMA_TIMEOUT_SECONDS=420
# Base URL used by ai-stats to query ai-api monitoring/cache internals.
AI_ENGINE_GENERATION_API_URL=http://ai-api:8001
# Persistent cache file for generated responses
AI_ENGINE_GENERATION_CACHE_PATH=data/generation_cache.json
# Persistent backend: tinydb or redis
AI_ENGINE_GENERATION_CACHE_BACKEND=redis
# Redis URL and key prefix (used only when backend=redis)
AI_ENGINE_GENERATION_CACHE_REDIS_URL=redis://ai-cache:6379/0
AI_ENGINE_GENERATION_CACHE_REDIS_PREFIX=ai-engine:generation-cache
# Cache namespace/version (bump to force a new cache namespace)
AI_ENGINE_GENERATION_CACHE_NAMESPACE=v1

# Request-level rate limiting for generation endpoints
AI_ENGINE_RATE_LIMIT_ENABLED=false
AI_ENGINE_RATE_LIMIT_REQUESTS=60
AI_ENGINE_RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# Security  (generation API)
# ---------------------------------------------------------------------------

# API key for game microservices calling generation endpoints (/generate*).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AI_ENGINE_GAMES_API_KEY=change_me_games_api_key

# API key for bridge microservice calling ingest and observability endpoints.
AI_ENGINE_BRIDGE_API_KEY=change_me_bridge_api_key

# API key used internally by ai-api when publishing events to ai-stats (/events).
AI_ENGINE_STATS_API_KEY=change_me_stats_api_key

# Optional global fallback API key for backward compatibility.
# Prefer scoped keys above for production.
# AI_ENGINE_API_KEY=change_me_legacy_api_key

# ---------------------------------------------------------------------------
# Image and container naming convention
# Pattern used in docker-compose for built services:
#   NombreApp_NombreServicio_Distribucion_version
# Example:
# Container naming convention:
#   ai_engine_{service}_{distribution}_{version}
# Examples:
#   ai_engine_api_dev_v1
#   ai_engine_stats_pro_v1
#   ai_engine_llama_cpu_dev_v1
# ---------------------------------------------------------------------------

# Application base name (used in Dockerfile labels).
APP_NAME=ai_engine

# Distribution and release version suffixes.
AI_ENGINE_DISTRIBUTION=dev
AI_ENGINE_RELEASE_VERSION=v1
