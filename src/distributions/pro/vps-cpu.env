# pro + vps-cpu  (target: VPS 8 cores / 32 GB RAM — production baseline)
# This is the minimum optimized profile. Scale up by increasing LLAMA_THREADS,
# LLAMA_PARALLEL, LLAMA_BATCH or switching to a 7B model when resources allow.
AI_ENGINE_MODELS_DIR=./models
LLAMA_MODEL_FILE=Qwen2.5-3B-Instruct-Q4_K_M.gguf

LLAMA_PORT=8080
STATS_PORT=8000
API_PORT=8001

# ── LLM inference (native llama.cpp server) ──────────────────────────────────
# CTX_SIZE 2048: sufficient for game prompts (~1200 input + 512 output tokens)
# THREADS 4: half of 8 cores — leaves room for ai-api + other services
# BATCH 1024: fast prompt prefill (higher = fewer iterations to process input)
# PARALLEL 2: serve 2 concurrent requests (each allocates its own KV cache)
# MLOCK: always enabled in docker-compose (pins model in RAM)
LLAMA_CTX_SIZE=2048
LLAMA_THREADS=4
LLAMA_BATCH=1024
LLAMA_PARALLEL=2

LLAMA_CPUS=4.0
LLAMA_MEMORY_LIMIT=10g
LLAMA_MEMORY_RESERVATION=6g
LLAMA_SHM_SIZE=1g

# ── AI API ───────────────────────────────────────────────────────────────────
API_CPUS=1.5
API_MEMORY_LIMIT=4g
API_MEMORY_RESERVATION=2g
API_SHM_SIZE=512m
API_WORKERS=2

# ── Stats / Observability ────────────────────────────────────────────────────
STATS_CPUS=0.5
STATS_MEMORY_LIMIT=512m
STATS_MEMORY_RESERVATION=256m
STATS_WORKERS=1

# ── Cache (Redis) ────────────────────────────────────────────────────────────
CACHE_CPUS=0.25
CACHE_MEMORY_LIMIT=256m
CACHE_MEMORY_RESERVATION=128m

# ── Application config ───────────────────────────────────────────────────────
AI_ENGINE_EMBEDDING_MODEL=all-MiniLM-L6-v2
AI_ENGINE_LLAMA_TIMEOUT_SECONDS=600
AI_ENGINE_GENERATION_API_URL=http://ai-api:8001
AI_ENGINE_GENERATION_CACHE_BACKEND=redis
AI_ENGINE_GENERATION_CACHE_PATH=/app/data/generation_cache.json
AI_ENGINE_GENERATION_CACHE_REDIS_URL=redis://ai-cache:6379/0
AI_ENGINE_GENERATION_CACHE_REDIS_PREFIX=ai-engine:generation-cache
AI_ENGINE_GENERATION_CACHE_NAMESPACE=pro-v1

AI_ENGINE_RATE_LIMIT_ENABLED=true
AI_ENGINE_RATE_LIMIT_REQUESTS=60
AI_ENGINE_RATE_LIMIT_WINDOW_SECONDS=60

APP_NAME=ai_engine

AI_ENGINE_DISTRIBUTION=pro
AI_ENGINE_RELEASE_VERSION=v1
AI_ENGINE_API_KEY=pro_api_test_key_2026
AI_ENGINE_GAMES_API_KEY=pro_games_test_key_2026
AI_ENGINE_BRIDGE_API_KEY=pro_bridge_test_key_2026
AI_ENGINE_STATS_API_KEY=pro_stats_test_key_2026
