# pro + windows
AI_ENGINE_MODELS_DIR=./models
LLAMA_MODEL_FILE=Qwen2.5-7B-Instruct-Q4_K_M.gguf

LLAMA_PORT=18080
STATS_PORT=8000
API_PORT=8001

LLAMA_CTX_SIZE=4096
LLAMA_THREADS=4
LLAMA_BATCH=512

LLAMA_CPUS=4.0
LLAMA_MEMORY_LIMIT=12g
LLAMA_MEMORY_RESERVATION=8g
LLAMA_SHM_SIZE=2g

API_CPUS=2.0
API_MEMORY_LIMIT=6g
API_MEMORY_RESERVATION=4g
API_SHM_SIZE=1g
API_WORKERS=2

STATS_CPUS=1.0
STATS_MEMORY_LIMIT=1g
STATS_MEMORY_RESERVATION=512m
STATS_WORKERS=1

AI_ENGINE_EMBEDDING_MODEL=all-MiniLM-L6-v2
AI_ENGINE_GENERATION_CACHE_BACKEND=tinydb
AI_ENGINE_GENERATION_CACHE_PATH=/app/data/generation_cache.json
AI_ENGINE_GENERATION_CACHE_REDIS_PREFIX=ai-engine:generation-cache
AI_ENGINE_GENERATION_CACHE_NAMESPACE=pro-v1

AI_ENGINE_RATE_LIMIT_ENABLED=true
AI_ENGINE_RATE_LIMIT_REQUESTS=60
AI_ENGINE_RATE_LIMIT_WINDOW_SECONDS=60
AI_ENGINE_API_KEY=pro-change-me

AI_ENGINE_DISTRIBUTION=pro
AI_ENGINE_RELEASE_VERSION=v1
