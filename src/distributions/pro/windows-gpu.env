# pro + windows-gpu (high-capacity workstation target)
AI_ENGINE_MODELS_DIR=./models
LLAMA_MODEL_FILE=Qwen2.5-7B-Instruct-Q4_K_M.gguf

LLAMA_PORT=18080
STATS_PORT=8000
API_PORT=8001

LLAMA_CTX_SIZE=8192
LLAMA_THREADS=12
LLAMA_BATCH=2048
LLAMA_N_GPU_LAYERS=99
LLAMA_PARALLEL=4

LLAMA_CPUS=12.0
LLAMA_MEMORY_LIMIT=24g
LLAMA_MEMORY_RESERVATION=18g
LLAMA_SHM_SIZE=4g

API_CPUS=6.0
API_MEMORY_LIMIT=12g
API_MEMORY_RESERVATION=8g
API_SHM_SIZE=2g
API_WORKERS=1

STATS_CPUS=1.5
STATS_MEMORY_LIMIT=1536m
STATS_MEMORY_RESERVATION=768m
STATS_WORKERS=1

CACHE_CPUS=0.5
CACHE_MEMORY_LIMIT=512m
CACHE_MEMORY_RESERVATION=256m

AI_ENGINE_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
AI_ENGINE_EMBEDDING_DEVICE=cpu
AI_ENGINE_EMBEDDING_BATCH_SIZE=128
AI_ENGINE_LLAMA_TIMEOUT_SECONDS=1200
AI_ENGINE_LLAMA_MAX_CONCURRENT_REQUESTS=4
AI_ENGINE_GENERATION_MAX_IN_FLIGHT=8
AI_ENGINE_GENERATION_MAX_QUEUE_SIZE=16
AI_ENGINE_QUERY_EMBEDDING_CACHE_MAX_ENTRIES=8192
AI_ENGINE_RETRIEVAL_RESULT_CACHE_MAX_ENTRIES=4096
AI_ENGINE_RAG_CONTEXT_CHAR_LIMIT=5200
AI_ENGINE_CACHE_WARMUP_ENABLED=false
AI_ENGINE_GENERATION_API_URL=http://ai-api:8001
AI_ENGINE_GENERATION_CACHE_BACKEND=redis
AI_ENGINE_GENERATION_CACHE_PATH=/app/data/generation_cache.json
AI_ENGINE_GENERATION_CACHE_REDIS_URL=redis://ai-cache:6379/0
AI_ENGINE_GENERATION_CACHE_REDIS_PREFIX=ai-engine:generation-cache
AI_ENGINE_GENERATION_CACHE_NAMESPACE=pro-gpu-v1

AI_ENGINE_RATE_LIMIT_ENABLED=true
AI_ENGINE_RATE_LIMIT_REQUESTS=240
AI_ENGINE_RATE_LIMIT_WINDOW_SECONDS=60

APP_NAME=ai_engine

AI_ENGINE_DISTRIBUTION=pro
AI_ENGINE_RELEASE_VERSION=workstation-gpu
AI_ENGINE_API_KEY=
AI_ENGINE_GAMES_API_KEY=
AI_ENGINE_BRIDGE_API_KEY=
AI_ENGINE_STATS_API_KEY=