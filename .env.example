# Example environment variables for AI-Engine
AI_ENGINE_ENV=local
# Path to local gguf/ggml model file
MODEL_PATH=models/llama/model.gguf
# Hugging Face token (for downloads)
HUGGINGFACE_TOKEN=
# Chroma persistence dir (if using chroma)
CHROMA_PERSIST_DIR=.chromadb
# Database URL for production
DATABASE_URL=postgresql://user:pass@host:5432/dbname
